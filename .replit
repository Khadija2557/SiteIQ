modules = ["nodejs-24", "postgresql-16", "python-3.12"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "SiteIQ API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "SiteIQ Frontend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "SiteIQ CV Service"

[[workflows.workflow]]
name = "SiteIQ API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[[workflows.workflow]]
name = "SiteIQ Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/ pnpm --filter @workspace/siteiq run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "SiteIQ CV Service"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd cv-service && python main.py"
waitForPort = 9000

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 9000
externalPort = 9000

[[ports]]
localPort = 23183
externalPort = 3002

[userenv]

[userenv.shared]
PORT = "8080"
BASE_PATH = "/"
